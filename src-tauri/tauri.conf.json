{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sovereign Pair",
  "version": "1.2.11",
  "identifier": "com.sovereign.pair",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Sovereign Pair",
        "label": "main",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      },
      {
        "title": "Sovereign Spotlight",
        "label": "spotlight",
        "url": "/spotlight",
        "width": 750,
        "height": 500,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: http://127.0.0.1:38001 https:; connect-src 'self' http://127.0.0.1:38001 http://127.0.0.1:11434 http://127.0.0.1:7860 https:; media-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sovereign-core"
    ],
    "resources": [
      "../../infra/plasma-widget/**/*"
    ]
  }
}
